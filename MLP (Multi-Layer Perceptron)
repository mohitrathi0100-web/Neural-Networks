Implements a Multi-Layer Perceptron neural network model with hidden layers to perform nonlinear classification tasks.
from sklearn.neural_network import MLPClassifier

X = [[0,0],[0,1],[1,0],[1,1]]
y = [0,1,1,0]

mlp = MLPClassifier(
    hidden_layer_sizes=(5,),
    activation='relu',
    max_iter=2000
)

mlp.fit(X, y)

print("MLP Predictions:")
print(mlp.predict(X))

