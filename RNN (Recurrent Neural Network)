Implements SimpleRNN layer to process sequential input data and capture time-dependent patterns in sequences.  
import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import SimpleRNN, Dense

model = Sequential([
    SimpleRNN(50, input_shape=(10,1)),
    Dense(1)
])

model.compile(
    optimizer='adam',
    loss='mse'
)

print("RNN Model Created")

